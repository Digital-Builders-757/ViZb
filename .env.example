# Copy to `.env.local` at the repo root. Next.js only loads names like `.env.local`;
# a file named `env.local` (no leading dot) is not applied.

# ----------------------------
# App / URLs
# ----------------------------
NEXT_PUBLIC_SITE_URL="https://<your-domain>"

# ----------------------------
# Supabase (public + server)
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<public_anon_key>"

# (Server-side convenience duplicates used in some codepaths)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<public_anon_key>"

# Server-only (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"

# Used by scripts / tooling
SUPABASE_PROJECT_ID="<project-ref>"
SUPABASE_ACCESS_TOKEN="<supabase_personal_access_token>"
# ----------------------------
# Email (Resend)
# ----------------------------
# Used by the app for /advertise (see app/actions/advertise-contact.ts).
# Sign-up & auth emails are sent by Supabase Auth — paste the SAME API key (or a dedicated key)
# into Supabase Dashboard → Authentication → SMTP (see docs/guides/SUPABASE_AUTH_EMAIL_RESEND.md).
RESEND_API_KEY="<resend_api_key>"
# Inbox for partnership / advertising leads (default in code: admin@thevavibe.com)
ADMIN_EMAIL="admin@thevavibe.com"
# Verified sender in Resend (required for production). Example: "ViZb <partners@yourdomain.com>"
# For Resend onboarding tests only: "ViZb <onboarding@resend.dev>"
RESEND_FROM=""

# ----------------------------
# Sentry (Dev + Prod)
# ----------------------------
SENTRY_DSN_DEV="<sentry_dsn_dev>"
NEXT_PUBLIC_SENTRY_DSN_DEV="<sentry_dsn_dev>"

SENTRY_DSN_PROD="<sentry_dsn_prod>"
NEXT_PUBLIC_SENTRY_DSN_PROD="<sentry_dsn_prod>"
# Sentry upload/auth (server/CI only)
SENTRY_AUTH_TOKEN="<sentry_auth_token>"
SENTRY_ORG="<sentry_org_slug>"
SENTRY_PROJECT="<sentry_project_slug>"

# ----------------------------
# Stripe
# ----------------------------
STRIPE_WEBHOOK_SECRET="<stripe_webhook_signing_secret>"

# Server-only
STRIPE_SECRET_KEY="<stripe_secret_key>"

# Client-safe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="<stripe_publishable_key>"
# Prices (IDs from Stripe dashboard)
STRIPE_PRICE_TALENT_MONTHLY="<price_id>"
STRIPE_PRICE_TALENT_ANNUAL="<price_id>"

# ----------------------------
# Wallet passes (Apple + Google) — optional; buttons stay hidden until configured
# ----------------------------
# Shared HMAC secret for QR / barcode payload on passes (no PII in the message).
TICKET_BARCODE_HMAC_SECRET="<long_random_string>"

# Apple Wallet (.pkpass) — Pass Type ID certificate as base64 PKCS#12 + Apple WWDR PEM (base64)
APPLE_WALLET_TEAM_ID="<10_char_team_id>"
APPLE_WALLET_PASS_TYPE_ID="pass.<your.pass.type.id>"
APPLE_WALLET_ORG_NAME="ViZb"
APPLE_WALLET_CERT_P12_BASE64="<base64_of_signing_certificate.p12>"
APPLE_WALLET_CERT_PASSWORD="<p12_export_password>"
APPLE_WALLET_WWDR_PEM_BASE64="<base64_of_Apple_WWDR_G4.pem>"

# Google Wallet — service account JSON (single-line file as base64)
GOOGLE_WALLET_ISSUER_ID="<numeric_issuer_id>"
GOOGLE_WALLET_CLASS_ID="<issuer_id>.<class_suffix_or_full_class_id>"
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_BASE64="<base64_of_service_account.json>"


